<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F4"
    android:layoutDirection="rtl">

<LinearLayout
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<TextView
    android:text="Installer"
    android:textSize="30sp"
    android:textStyle="bold"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"/>

<TextView
    android:text="התקנה, רקע, Boot Logo, APN ובדיקת אינטרנט"
    android:textSize="16sp"
    android:layout_marginTop="6dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"/>

<Button
    android:id="@+id/installApps"
    android:text="🟢⬇ התקן אפליקציות"
    android:textColor="#FFFFFF"
    android:background="#842F1B"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="20dp"/>

<Button
    android:id="@+id/setWallpaper"
    android:text="🖼 שנה רקע מסך"
    android:textColor="#FFFFFF"
    android:background="#A34128"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="12dp"/>

<Button
    android:id="@+id/setBootlogo"
    android:text="🚗 שנה Boot Logo"
    android:textColor="#FFFFFF"
    android:background="#B55537"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="12dp"/>

<Button
    android:id="@+id/openApn"
    android:text="📶 פתח הגדרות APN (הועתק ללוח)"
    android:textColor="#FFFFFF"
    android:background="#C66B49"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="12dp"/>

<Button
    android:id="@+id/checkInternet"
    android:text="🌐 בדיקת אינטרנט"
    android:textColor="#FFFFFF"
    android:background="#D27D5E"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:layout_marginTop="12dp"/>

<TextView
    android:id="@+id/status"
    android:text="מוכן"
    android:textSize="17sp"
    android:layout_marginTop="20dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"/>

<ImageView
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_marginTop="30dp"
    android:scaleType="fitCenter"
    android:src="@drawable/stereo_logo"/>

</LinearLayout>
</ScrollView>
